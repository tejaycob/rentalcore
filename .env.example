# Copy this file to .env — @nestjs/config loads it automatically on
# startup, no manual export needed.

# ── Database ─────────────────────────────────────────────────────────
# Full Postgres connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/rental_saas

# ── Server ────────────────────────────────────────────────────────────
PORT=3000

# ── Secrets encryption (src/crypto/secrets.service.ts) ─────────────────
# 32 random bytes, base64-encoded. Generate with: openssl rand -base64 32
# Production: source this from a real KMS, not a plain env var.
ENCRYPTION_MASTER_KEY=

# ── Payment provider credentials ────────────────────────────────────────
# These are NOT read directly by the app — they get encrypted and stored
# per-company in company_payment_configs.encrypted_credentials via your
# own onboarding flow (not yet built). Listed here only so you know what
# each provider integration eventually needs.
#
# Paysuite (Mozambique)   — needs confirming against their real API docs
# AppyPay  (Angola)       — needs confirming against their real API docs
# Ozow     (South Africa) — needs confirming against their real API docs
# Paystack (South Africa) — secret key + webhook secret, from their dashboard
